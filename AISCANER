        const scanPercentage = document.getElementById('scan-percentage');
        const progressBar = document.getElementById('progress-bar');
        
        const log1 = document.getElementById('log-line-1');
        const log2 = document.getElementById('log-line-2');
        const log3 = document.getElementById('log-line-3');

        // Клик по СТАРТУ
        btnStart.addEventListener('click', () => {
            initAudio();
            playBeep(440, 'sine', 0.08);
            
            screenIntro.classList.add('opacity-0', 'scale-95');
            setTimeout(() => {
                screenIntro.classList.add('hidden');
                screenScanning.classList.remove('hidden');
                
                setTimeout(() => {
                    screenScanning.classList.remove('opacity-0', 'scale-95');
                    runScanning();
                }, 50);
            }, 300);
        });

        function runScanning() {
            let progress = 0;
            const dict = TRANSLATIONS[currentLang];
            const activeLogs = [dict.log1, dict.log2, dict.log3, dict.log4];
            let logIndex = 0;
            
            startScanTicks();

            const scanInterval = setInterval(() => {
                if (progress < 100) {
                    progress += Math.floor(Math.random() * 4) + 1;
                    if (progress > 100) progress = 100;
                    
                    scanPercentage.innerText = progress + '%';
                    progressBar.style.width = progress + '%';

                    // Шаг вывода текстовых логов на основе прогресса
                    const nextLogThreshold = Math.floor((logIndex + 1) * (100 / activeLogs.length));
                    if (progress >= nextLogThreshold && logIndex < activeLogs.length) {
                        log1.innerText = log2.innerText;
                        log2.innerText = log3.innerText;
                        log3.innerText = "> " + activeLogs[logIndex];
                        logIndex++;
                    }
                } else {
                    clearInterval(scanInterval);
                    stopScanTicks();
                    finishScanning();
                }
            }, 80);
        }

        function finishScanning() {
            setTimeout(() => {
                screenScanning.classList.add('opacity-0', 'scale-95');
                setTimeout(() => {
                    screenScanning.classList.add('hidden');
                    screenResult.classList.remove('hidden');
                    startCountdown(); 
                    setTimeout(() => {
                        screenResult.classList.remove('opacity-0', 'scale-95');
                    }, 50);
                }, 300);
            }, 400);
        }

