                    <span class="text-emerald-400">${slot}</span>
                </div>
                <div class="text-emerald-400 font-extrabold">+${formattedAmount}</div>
            `;
            
            liveContainer.prepend(item);
            
            // Плавный влет строки
            setTimeout(() => {
                item.classList.remove('opacity-0', 'translate-y-2');
            }, 50);

            // Держим не более 2 логов в футере для чистоты на мобильных
            if (liveContainer.children.length > 2) {
                liveContainer.lastElementChild.remove();
            }
        }

        // Запуск живых побед на старте
        setInterval(generateWinLog, 4000 + Math.random() * 2500);
        
        // Установка стартового языка
        const initialLang = detectUserLanguage();
        updateLanguageUI(initialLang);

        // Первая генерация лога
        generateWinLog();
        setTimeout(generateWinLog, 1500);

        // Установка целевой ссылки
        ctaLink.href = TARGET_URL;
    </script>
</body>
</html>
