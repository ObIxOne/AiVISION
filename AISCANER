        let audioCtx = null;
        function initAudio() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
        }

        function playBeep(freq, type, duration) {
            try {
                initAudio();
                if (audioCtx.state === 'suspended') {
                    audioCtx.resume();
                }
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                
                osc.type = type;
                osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
                
                gain.gain.setValueAtTime(0.04, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);
                
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                
                osc.start();
                osc.stop(audioCtx.currentTime + duration);
            } catch (e) {
                // Игнорируем в случае блокировок встроенных браузеров
            }
        }

        let scanHumInterval = null;
        function startScanTicks() {
            scanHumInterval = setInterval(() => {
                playBeep(250 + Math.random() * 50, 'sine', 0.1);
            }, 200);
        }

        function stopScanTicks() {
            if (scanHumInterval) clearInterval(scanHumInterval);
            // Победный приятный звон
            setTimeout(() => playBeep(523, 'triangle', 0.2), 0);
            setTimeout(() => playBeep(659, 'triangle', 0.2), 80);
            setTimeout(() => playBeep(784, 'triangle', 0.3), 160);
        }

        const langSelector = document.getElementById('lang-selector');
        let currentLang = 'en';

        // Автоматическое определение языка устройства
        function detectUserLanguage() {
            const userLang = (navigator.language || navigator.userLanguage || 'en').substring(0, 2).toLowerCase();
            if (TRANSLATIONS[userLang]) {
                return userLang;
            }
            return 'en'; // дефолт
        }

        // Функция обновления текстового наполнения страницы под выбранный язык
        function updateLanguageUI(lang) {
            currentLang = lang;
            langSelector.value = lang;
            
            const dict = TRANSLATIONS[lang];
            
            // Направление текста для арабского языка
            if (lang === 'ar') {
                document.documentElement.dir = 'rtl';
                document.getElementById('lang-selector').style.backgroundPosition = "left 8px center";
            } else {
                document.documentElement.dir = 'ltr';
                document.getElementById('lang-selector').style.backgroundPosition = "right 8px center";
            }

            // Массовое обновление статических текстов
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (dict[key]) {
                    el.innerText = dict[key];
                }
            });

            // Локализация второстепенных элементов
            document.getElementById('live-wins-header').innerHTML = `
                <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full mr-1.5 active-pulse-dot"></span>
                ${dict.footerLabel}
            `;

            // Обновляем шапку
            document.getElementById('header-logo-text').innerText = lang === 'ar' ? 'ماسح الذكاء الاصطناعي v6.0' : 'AI SCANNER v6.0';
            document.getElementById('stat-info-title-1').innerText = lang === 'ru' ? 'Провайдеры' : (lang === 'uk' ? 'Провайдери' : (lang === 'ar' ? 'المزودين' : 'Providers'));
            document.getElementById('stat-info-title-2').innerText = lang === 'ru' ? 'Шанс отдачи' : (lang === 'uk' ? 'Шанс віддачі' : (lang === 'ar' ? 'معدل العائد' : 'Win-Rate'));
        }

        // Изменение языка через селектор вручную
        langSelector.addEventListener('change', (e) => {
            updateLanguageUI(e.target.value);
            playBeep(440, 'sine', 0.08);
        });

